# ─────────────────────────────────────────────────────────────
# Single root .gitignore for the whole monorepo.
# Patterns without a leading slash match at any depth, so these
# cover backend/ and frontend/react-app/ too.
# ─────────────────────────────────────────────────────────────

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Node / Vite (frontend) ──
node_modules/
dist/
dist-ssr/
.vite/
*.local

# ── Python / uv (backend) ──
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
ENV/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/
*.egg-info/
.eggs/
build/
# NOTE: uv.lock and package-lock.json are committed for reproducible installs.

# ── Secrets / local env (sample/example files stay committed) ──
.env
.env.*
!.env.sample
!.env.example

# ── Uploaded files (document store — local storage backend) ──
uploads/

# ── Claude Code: shared config (CLAUDE.md, skills, agents, settings.json) is
#    committed; personal overrides stay local ──
.claude/settings.local.json

# ── Project-specific design / reference files ──
figma promt forms.md
qms_complete.html
qms frontend design.md
qms quality management system*
